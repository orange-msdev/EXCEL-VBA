function wordfinderleft(word as string,ws as worksheet) as wordfindinfo
  dim result as new wordfindinfo
  dim nstrlen as intger
  dim rngword as range
  dim stargetword as string
  dim findstartrow as string

  findstartrow = slogwordcolnm & slogwordrowidx
  nstrlen = len(word)
  for i = nstrlen to 1 step - 1
    stargetword = left(word,i)
    set rngword = ws.columns(slogwordcolnm).find(what:=stargetword,after:=ws.range(findstartrow),lookin:=xlvalues,lookat:=xlwhole)
    if not rnword is nothing then
      result.foundword = stargetword
      result.isexists = true
      result.wordrowidx = rngword.row
      result.orgword = word
      set wordfinderleft = result
      exit function
    end if
  next i
  result.foundword = stargetword
  result.isexists = false
  result.orgword = word
  result.wordrowidx = 0
  set wordfinderleft = result
  exit function
end function

function wordfinderright(word as string,ws as worksheet) as wordfindinfo
